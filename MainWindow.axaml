<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:BreathingApp"
        x:Class="BreathingApp.MainWindow"
        x:DataType="local:BreathingViewModel"
        Title="Box Breathing"
        Width="400" Height="480">
    
    <Window.DataContext>
        <local:BreathingViewModel />
    </Window.DataContext>

    <StackPanel Margin="20">
        <TextBlock Text="{Binding PhaseText}" 
                   FontSize="32" 
                   HorizontalAlignment="Center"
                   Margin="0,0,0,20"/>

        <Canvas Width="300" Height="300" 
                Background="LightGray"
                HorizontalAlignment="Center">
            <Rectangle Stroke="#EE0202" StrokeThickness="3"
                       Width="200" Height="200"
                       Canvas.Left="50" Canvas.Top="50"
                       Fill="Transparent"/>
            <Ellipse Width="30" Height="30" Fill="#FFFB00"
                     Canvas.Left="{Binding BallX}"
                     Canvas.Top="{Binding BallY}"/>
        </Canvas>

        <!-- Single toggle button -->
        <Button Content="{Binding ButtonText}" 
                HorizontalAlignment="Center"
                Margin="0,30,0,0"
                Click="OnToggleClick"/>
    </StackPanel>
</Window>